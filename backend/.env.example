# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
TIME_ZONE=UTC

# ── Database — PostgreSQL ──────────────────────────────────────────────────────
# Setup: createdb estatemind_db && createuser -P estatemind_user
# Grant: GRANT ALL PRIVILEGES ON DATABASE estatemind_db TO estatemind_user;
USE_SQLITE=False
DB_NAME=estatemind_db
DB_USER=estatemind_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable          # use 'require' or 'verify-full' in production
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=False  # set True in production (requires CONN_MAX_AGE > 0)

# ── Hosts & CORS ───────────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Dev cookies over HTTP ──────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── Email ──────────────────────────────────────────────────────────────────────
# Development (writes to backend/emails/ directory):
# EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
# Production (Gmail SMTP — create App Password at myaccount.google.com/apppasswords):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
